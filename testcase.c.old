// KVStore 自动化测试框架
// 支持 RESP 协议、多引擎测试、性能测试、并发测试、持久化测试

#include <netdb.h>
#include <arpa/inet.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <sys/time.h>
#include <unistd.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <signal.h>
#include <time.h>

#define MAX_MSG 1024
#define MAX_RESP 4096
#define MAX_CMD 256
#define MAX_TEST_NAME 128

// 时间计算宏
#define TIME_SUB_MS(tv1, tv2) ((tv1.tv_sec - tv2.tv_sec) * 1000 + (tv1.tv_usec - tv2.tv_usec) / 1000)

// 测试结果枚举
typedef enum {
    TEST_PASS,
    TEST_FAIL,
    TEST_SKIP
} test_result_t;

// 测试统计结构
typedef struct {
    int total;
    int passed;
    int failed;
    int skipped;
    long long total_time_ms;
} test_stats_t;

// 性能测试结果
typedef struct {
    char test_name[MAX_TEST_NAME];
    int operations;
    long long time_ms;
    int qps;
    test_result_t result;
} perf_test_result_t;

// 全局测试统计
static test_stats_t g_stats = {0};
static perf_test_result_t g_perf_results[100];
static int g_perf_count = 0;
static FILE* g_markdown_report = NULL;

/* ==================== 基础网络函数 ==================== */

/**
 * 连接到服务器
 */
int connect_server(const char *ip, unsigned short port) {
    int connfd = socket(AF_INET, SOCK_STREAM, 0);
    if (connfd < 0) {
        perror("socket");
        return -1;
    }

    struct sockaddr_in server_addr = {0};
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(port);
    int ret = inet_pton(AF_INET, ip, &server_addr.sin_addr);
    if (!ret) {
        fprintf(stderr, "Not a valid IPv4\n");
        close(connfd);
        return -1;
    }

    if (connect(connfd, (struct sockaddr*)&server_addr, sizeof(struct sockaddr_in)) != 0) {
        perror("connect");
        close(connfd);
        return -1;
    }
    return connfd;
}

/**
 * 发送消息
 */
int send_msg(int connfd, char* msg, int length) {
    int res = send(connfd, msg, length, 0);
    if (res < 0) {
        perror("send");
        return -1;
    }
    return res;
}

/**
 * 接收消息
 */
int recv_msg(int connfd, char* result, int length) {
    int res = recv(connfd, result, length, 0);
    if (res < 0) {
        perror("recv");
        return -1;
    }
    return res;
}

/* ==================== RESP 协议编码/解码 ==================== */

/**
 * RESP 编码函数：将自定义文本协议转换为 RESP 协议格式
 * 输入: "SET key value"
 * 输出: "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"
 */
char* encode_to_resp(const char* cmd) {
    if (cmd == NULL || strlen(cmd) == 0) {
        return NULL;
    }

    char* cmd_copy = strdup(cmd);
    if (cmd_copy == NULL) {
        return NULL;
    }

    char* args[64];
    int argc = 0;
    char* token = strtok(cmd_copy, " ");

    while (token != NULL && argc < 64) {
        args[argc++] = token;
        token = strtok(NULL, " ");
    }

    if (argc == 0) {
        free(cmd_copy);
        return NULL;
    }

    // 计算总长度
    int total_len = 0;
    total_len += snprintf(NULL, 0, "*%d\r\n", argc);
    for (int i = 0; i < argc; i++) {
        int arg_len = strlen(args[i]);
        total_len += snprintf(NULL, 0, "$%d\r\n%s\r\n", arg_len, args[i]);
    }

    // 分配内存
    char* resp = (char*)malloc(total_len + 2);
    if (resp == NULL) {
        free(cmd_copy);
        return NULL;
    }

    // 生成 RESP 格式
    int offset = 0;
    offset += snprintf(resp + offset, total_len - offset + 1, "*%d\r\n", argc);
    for (int i = 0; i < argc; i++) {
        int arg_len = strlen(args[i]);
        int written = snprintf(resp + offset, total_len - offset + 1, "$%d\r\n%s\r\n", arg_len, args[i]);
        offset += written;
    }
    resp[offset] = '\0';

    free(cmd_copy);
    return resp;
}

/**
 * 响应格式转换：将 kvs_protocol 响应转换为 RESP 响应格式
 */
const char* convert_response_to_resp(const char* pattern) {
    if (pattern == NULL) return NULL;

    // OK\r\n -> +OK\r\n
    if (strcmp(pattern, "OK\r\n") == 0) {
        return "+OK\r\n";
    }

    // ERROR\r\n -> -ERROR\r\n
    if (strcmp(pattern, "ERROR\r\n") == 0) {
        return "-ERROR\r\n";
    }

    // YES, Exist\r\n -> :1\r\n
    if (strcmp(pattern, "YES, Exist\r\n") == 0) {
        return ":1\r\n";
    }

    // NO, Not Exist\r\n -> :0\r\n
    if (strcmp(pattern, "NO, Not Exist\r\n") == 0) {
        return ":0\r\n";
    }

    // Key has existed\r\n -> -Key has existed\r\n
    if (strcmp(pattern, "Key has existed\r\n") == 0) {
        return "-Key has existed\r\n";
    }

    // Not Exist\r\n -> -Not Exist\r\n
    if (strcmp(pattern, "Not Exist\r\n") == 0) {
        return "-Not Exist\r\n";
    }

    // ERROR / Not Exist\r\n -> -ERROR / Not Exist\r\n
    if (strcmp(pattern, "ERROR / Not Exist\r\n") == 0) {
        return "-ERROR / Not Exist\r\n";
    }

    // 其他情况：转换为 bulk string 格式
    int len = strlen(pattern);
    if (len >= 2 && pattern[len - 1] == '\n' && pattern[len - 2] == '\r') {
        static char resp_pattern[256];
        int value_len = len - 2;
        snprintf(resp_pattern, sizeof(resp_pattern), "$%d\r\n%.*s\r\n", value_len, value_len, pattern);
        return resp_pattern;
    }

    return pattern;
}

/* ==================== 测试框架函数 ==================== */

/**
 * 初始化测试统计
 */
void test_stats_init() {
    memset(&g_stats, 0, sizeof(test_stats_t));
    g_perf_count = 0;
}

/**
 * 记录测试结果
 */
void test_record_result(test_result_t result, const char* test_name) {
    g_stats.total++;
    if (result == TEST_PASS) {
        g_stats.passed++;
        printf("[PASS] %s\n", test_name);
        if (g_markdown_report) {
            fprintf(g_markdown_report, "| %s | PASS |\n", test_name);
        }
    } else if (result == TEST_FAIL) {
        g_stats.failed++;
        printf("[FAIL] %s\n", test_name);
        if (g_markdown_report) {
            fprintf(g_markdown_report, "| %s | FAIL |\n", test_name);
        }
    } else {
        g_stats.skipped++;
        printf("[SKIP] %s\n", test_name);
        if (g_markdown_report) {
            fprintf(g_markdown_report, "| %s | SKIP |\n", test_name);
        }
    }
}

/**
 * 记录性能测试结果
 */
void test_record_perf(const char* test_name, int operations, long long time_ms) {
    if (g_perf_count >= 100) return;

    int qps = (operations * 1000) / time_ms;
    strncpy(g_perf_results[g_perf_count].test_name, test_name, MAX_TEST_NAME - 1);
    g_perf_results[g_perf_count].test_name[MAX_TEST_NAME - 1] = '\0';
    g_perf_results[g_perf_count].operations = operations;
    g_perf_results[g_perf_count].time_ms = time_ms;
    g_perf_results[g_perf_count].qps = qps;
    g_perf_results[g_perf_count].result = TEST_PASS;
    g_perf_count++;

    printf("[PERF] %s: %d ops in %lld ms, QPS: %d\n", test_name, operations, time_ms, qps);
    if (g_markdown_report) {
        fprintf(g_markdown_report, "| %s | %d | %lld ms | %d |\n", test_name, operations, time_ms, qps);
    }
}

/**
 * 打印测试统计
 */
void test_stats_print() {
    printf("\n========== Test Summary ==========\n");
    printf("Total: %d, Passed: %d, Failed: %d, Skipped: %d\n",
           g_stats.total, g_stats.passed, g_stats.failed, g_stats.skipped);
    printf("Pass Rate: %.2f%%\n",
           g_stats.total > 0 ? (g_stats.passed * 100.0 / g_stats.total) : 0.0);
    printf("Total Time: %lld ms\n", g_stats.total_time_ms);
    printf("==================================\n");

    if (g_markdown_report) {
        fprintf(g_markdown_report, "\n## Test Summary\n\n");
        fprintf(g_markdown_report, "| Metric | Value |\n");
        fprintf(g_markdown_report, "|--------|-------|\n");
        fprintf(g_markdown_report, "| Total Tests | %d |\n", g_stats.total);
        fprintf(g_markdown_report, "| Passed | %d |\n", g_stats.passed);
        fprintf(g_markdown_report, "| Failed | %d |\n", g_stats.failed);
        fprintf(g_markdown_report, "| Skipped | %d |\n", g_stats.skipped);
        fprintf(g_markdown_report, "| Pass Rate | %.2f%% |\n",
                g_stats.total > 0 ? (g_stats.passed * 100.0 / g_stats.total) : 0.0);
        fprintf(g_markdown_report, "| Total Time | %lld ms |\n", g_stats.total_time_ms);
    }
}

/**
 * 初始化 Markdown 报告
 */
void test_markdown_init() {
    time_t now = time(NULL);
    struct tm* tm_info = localtime(&now);
    char filename[256];
    strftime(filename, sizeof(filename), "test_report_%Y%m%d_%H%M%S.md", tm_info);

    g_markdown_report = fopen(filename, "w");
    if (g_markdown_report) {
        fprintf(g_markdown_report, "# KVStore Test Report\n\n");
        fprintf(g_markdown_report, "Generated: %s\n\n", ctime(&now));
        fprintf(g_markdown_report, "## Test Results\n\n");
        fprintf(g_markdown_report, "| Test Name | Result |\n");
        fprintf(g_markdown_report, "|-----------|--------|\n");
        printf("Markdown report: %s\n", filename);
    }
}

/**
 * 关闭 Markdown 报告
 */
void test_markdown_close() {
    if (g_markdown_report) {
        fclose(g_markdown_report);
        g_markdown_report = NULL;
    }
}

/**
 * 基础测试用例函数
 */
void testcase(int connfd, char* msg, char* pattern, char* casename) {
    if (msg == NULL || pattern == NULL || casename == NULL) return;

    char* resp_msg = encode_to_resp(msg);
    if (resp_msg == NULL) {
        printf("[ERROR] %s: Failed to encode command to RESP\n", casename);
        exit(1);
    }

    send_msg(connfd, resp_msg, strlen(resp_msg));
    free(resp_msg);

    char result[MAX_MSG] = {0};
    recv_msg(connfd, result, MAX_MSG);

    const char* resp_pattern = convert_response_to_resp(pattern);

    if (!strcmp(result, resp_pattern)) {
        test_record_result(TEST_PASS, casename);
    } else {
        printf("[FAIL] %s: \n==> '%s' != '%s'\n", casename, result, resp_pattern);
        printf("msg is : %s\n", msg);
        test_record_result(TEST_FAIL, casename);
        exit(1);
    }
}

/* ==================== RESP 协议测试 ==================== */

/**
 * RESP 特殊字符测试
 */
void test_resp_special_chars(int connfd) {
    printf("\n--- Testing RESP Special Characters ---\n");

    // 测试 key 包含特殊字符
    testcase(connfd, "SET key$dollar value", "OK\r\n", "RESP-SET-key-dollar");
    testcase(connfd, "GET key$dollar", "value\r\n", "RESP-GET-key-dollar");
    testcase(connfd, "DEL key$dollar", "OK\r\n", "RESP-DEL-key-dollar");

    testcase(connfd, "SET key*star value", "OK\r\n", "RESP-SET-key-star");
    testcase(connfd, "GET key*star", "value\r\n", "RESP-GET-key-star");
    testcase(connfd, "DEL key*star", "OK\r\n", "RESP-DEL-key-star");

    testcase(connfd, "SET key\\r\\n value", "OK\r\n", "RESP-SET-key-crnl");
    testcase(connfd, "GET key\\r\\n", "value\r\n", "RESP-GET-key-crnl");
    testcase(connfd, "DEL key\\r\\n", "OK\r\n", "RESP-DEL-key-crnl");

    testcase(connfd, "SET key space value", "OK\r\n", "RESP-SET-key-space");
    testcase(connfd, "GET key space", "value\r\n", "RESP-GET-key-space");
    testcase(connfd, "DEL key space", "OK\r\n", "RESP-DEL-key-space");

    // 测试 value 包含特殊字符
    testcase(connfd, "SET key value$dollar", "OK\r\n", "RESP-SET-value-dollar");
    testcase(connfd, "GET key", "value$dollar\r\n", "RESP-GET-value-dollar");
    testcase(connfd, "DEL key", "OK\r\n", "RESP-DEL-value-dollar");

    testcase(connfd, "SET key value*star", "OK\r\n", "RESP-SET-value-star");
    testcase(connfd, "GET key", "value*star\r\n", "RESP-GET-value-star");
    testcase(connfd, "DEL key", "OK\r\n", "RESP-DEL-value-star");
}

/**
 * RESP 边界条件测试
 */
void test_resp_boundary(int connfd) {
    printf("\n--- Testing RESP Boundary Conditions ---\n");

    // 空 key
    testcase(connfd, "SET  value", "ERROR\r\n", "RESP-SET-empty-key");

    // 空 value
    testcase(connfd, "SET key ", "OK\r\n", "RESP-SET-empty-value");
    testcase(connfd, "GET key", "\r\n", "RESP-GET-empty-value");
    testcase(connfd, "DEL key", "OK\r\n", "RESP-DEL-empty-value");

    // 非常长的 key
    char long_key[256];
    memset(long_key, 'a', 255);
    long_key[255] = '\0';
    char cmd_set_long[512];
    snprintf(cmd_set_long, sizeof(cmd_set_long), "SET %s value", long_key);
    testcase(connfd, cmd_set_long, "OK\r\n", "RESP-SET-long-key");

    char cmd_get_long[512];
    snprintf(cmd_get_long, sizeof(cmd_get_long), "GET %s", long_key);
    testcase(connfd, cmd_get_long, "value\r\n", "RESP-GET-long-key");

    char cmd_del_long[512];
    snprintf(cmd_del_long, sizeof(cmd_del_long), "DEL %s", long_key);
    testcase(connfd, cmd_del_long, "OK\r\n", "RESP-DEL-long-key");
}

/* ==================== 基础操作测试 ==================== */

/**
 * 单引擎基础操作测试
 */
void test_single_engine_operations(int connfd) {
    printf("\n--- Testing Single Engine Operations ---\n");

    // SET/GET
    testcase(connfd, "SET key1 value1", "OK\r\n", "SINGLE-SET-1");
    testcase(connfd, "GET key1", "value1\r\n", "SINGLE-GET-1");

    // MOD
    testcase(connfd, "MOD key1 value1_modified", "OK\r\n", "SINGLE-MOD-1");
    testcase(connfd, "GET key1", "value1_modified\r\n", "SINGLE-GET-2");

    // MOD 不存在的 key
    testcase(connfd, "MOD key_not_exist value", "Not Exist\r\n", "SINGLE-MOD-2");

    // EXIST
    testcase(connfd, "EXIST key1", "YES, Exist\r\n", "SINGLE-EXIST-1");
    testcase(connfd, "EXIST key_not_exist", "NO, Not Exist\r\n", "SINGLE-EXIST-2");

    // DEL
    testcase(connfd, "DEL key1", "OK\r\n", "SINGLE-DEL-1");
    testcase(connfd, "EXIST key1", "NO, Not Exist\r\n", "SINGLE-EXIST-3");

    // GET 不存在的 key
    testcase(connfd, "GET key_not_exist", "ERROR / Not Exist\r\n", "SINGLE-GET-3");

    // DEL 不存在的 key
    testcase(connfd, "DEL key_not_exist", "Not Exist\r\n", "SINGLE-DEL-2");

    // 错误处理
    testcase(connfd, "SET", "ERROR\r\n", "SINGLE-ERROR-SET");
    testcase(connfd, "GET", "ERROR\r\n", "SINGLE-ERROR-GET");
    testcase(connfd, "DEL", "ERROR\r\n", "SINGLE-ERROR-DEL");
    testcase(connfd, "MOD", "ERROR\r\n", "SINGLE-ERROR-MOD");
    testcase(connfd, "EXIST", "ERROR\r\n", "SINGLE-ERROR-EXIST");
}

/**
 * 多引擎基础操作测试
 */
void test_multi_engine_operations(int connfd) {
    printf("\n--- Testing Multi-Engine Operations ---\n");

    // Array 引擎测试
    printf("\n  Testing Array Engine...\n");
    testcase(connfd, "ASET a_key1 a_value1", "OK\r\n", "ARRAY-SET-1");
    testcase(connfd, "AGET a_key1", "a_value1\r\n", "ARRAY-GET-1");
    testcase(connfd, "AMOD a_key1 a_value_modified", "OK\r\n", "ARRAY-MOD-1");
    testcase(connfd, "AGET a_key1", "a_value_modified\r\n", "ARRAY-GET-2");
    testcase(connfd, "AEXIST a_key1", "YES, Exist\r\n", "ARRAY-EXIST-1");
    testcase(connfd, "AEXIST a_not_exist", "NO, Not Exist\r\n", "ARRAY-EXIST-2");
    testcase(connfd, "ADEL a_key1", "OK\r\n", "ARRAY-DEL-1");
    testcase(connfd, "AEXIST a_key1", "NO, Not Exist\r\n", "ARRAY-EXIST-3");

    // Hash 引擎测试
    printf("\n  Testing Hash Engine...\n");
    testcase(connfd, "HSET h_key1 h_value1", "OK\r\n", "HASH-SET-1");
    testcase(connfd, "HGET h_key1", "h_value1\r\n", "HASH-GET-1");
    testcase(connfd, "HMOD h_key1 h_value_modified", "OK\r\n", "HASH-MOD-1");
    testcase(connfd, "HGET h_key1", "h_value_modified\r\n", "HASH-GET-2");
    testcase(connfd, "HEXIST h_key1", "YES, Exist\r\n", "HASH-EXIST-1");
    testcase(connfd, "HEXIST h_not_exist", "NO, Not Exist\r\n", "HASH-EXIST-2");
    testcase(connfd, "HDEL h_key1", "OK\r\n", "HASH-DEL-1");
    testcase(connfd, "HEXIST h_key1", "NO, Not Exist\r\n", "HASH-EXIST-3");

    // Rbtree 引擎测试
    printf("\n  Testing Rbtree Engine...\n");
    testcase(connfd, "RSET r_key1 r_value1", "OK\r\n", "RBTREE-SET-1");
    testcase(connfd, "RGET r_key1", "r_value1\r\n", "RBTREE-GET-1");
    testcase(connfd, "RMOD r_key1 r_value_modified", "OK\r\n", "RBTREE-MOD-1");
    testcase(connfd, "RGET r_key1", "r_value_modified\r\n", "RBTREE-GET-2");
    testcase(connfd, "REXIST r_key1", "YES, Exist\r\n", "RBTREE-EXIST-1");
    testcase(connfd, "REXIST r_not_exist", "NO, Not Exist\r\n", "RBTREE-EXIST-2");
    testcase(connfd, "RDEL r_key1", "OK\r\n", "RBTREE-DEL-1");
    testcase(connfd, "REXIST r_key1", "NO, Not Exist\r\n", "RBTREE-EXIST-3");

    // Skiplist 引擎测试
    printf("\n  Testing Skiplist Engine...\n");
    testcase(connfd, "SSET s_key1 s_value1", "OK\r\n", "SKIPLIST-SET-1");
    testcase(connfd, "SGET s_key1", "s_value1\r\n", "SKIPLIST-GET-1");
    testcase(connfd, "SMOD s_key1 s_value_modified", "OK\r\n", "SKIPLIST-MOD-1");
    testcase(connfd, "SGET s_key1", "s_value_modified\r\n", "SKIPLIST-GET-2");
    testcase(connfd, "SEXIST s_key1", "YES, Exist\r\n", "SKIPLIST-EXIST-1");
    testcase(connfd, "SEXIST s_not_exist", "NO, Not Exist\r\n", "SKIPLIST-EXIST-2");
    testcase(connfd, "SDEL s_key1", "OK\r\n", "SKIPLIST-DEL-1");
    testcase(connfd, "SEXIST s_key1", "NO, Not Exist\r\n", "SKIPLIST-EXIST-3");
}

/**
 * 引擎特定基础操作测试
 */
void test_engine_basic_operations(int connfd, const char* prefix) {
    char cmd[128];
    char name[128];

    printf("\n--- Testing %s Engine Basic Operations ---\n", prefix);

    // SET/GET
    snprintf(cmd, sizeof(cmd), "%sSET test_key test_value", prefix);
    testcase(connfd, cmd, "OK\r\n", "ENGINE-SET-1");

    snprintf(cmd, sizeof(cmd), "%sGET test_key", prefix);
    testcase(connfd, cmd, "test_value\r\n", "ENGINE-GET-1");

    // MOD
    snprintf(cmd, sizeof(cmd), "%sMOD test_key test_modified", prefix);
    testcase(connfd, cmd, "OK\r\n", "ENGINE-MOD-1");

    snprintf(cmd, sizeof(cmd), "%sGET test_key", prefix);
    testcase(connfd, cmd, "test_modified\r\n", "ENGINE-GET-2");

    // EXIST
    snprintf(cmd, sizeof(cmd), "%sEXIST test_key", prefix);
    testcase(connfd, cmd, "YES, Exist\r\n", "ENGINE-EXIST-1");

    // DEL
    snprintf(cmd, sizeof(cmd), "%sDEL test_key", prefix);
    testcase(connfd, cmd, "OK\r\n", "ENGINE-DEL-1");

    snprintf(cmd, sizeof(cmd), "%sEXIST test_key", prefix);
    testcase(connfd, cmd, "NO, Not Exist\r\n", "ENGINE-EXIST-2");
}

/* ==================== 性能测试 ==================== */

/**
 * 性能测试辅助函数
 */
void run_performance_test(int connfd, const char* test_name, const char* cmd_prefix, int count) {
    struct timeval tv_begin, tv_end;
    char cmd[256];

    gettimeofday(&tv_begin, NULL);

    for (int i = 0; i < count; i++) {
        snprintf(cmd, sizeof(cmd), "%s perf_key%d perf_value%d", cmd_prefix, i, i);
        testcase(connfd, cmd, "OK\r\n", "PERF-SET");
    }

    gettimeofday(&tv_end, NULL);
    long long time_used = TIME_SUB_MS(tv_end, tv_begin);
    test_record_perf(test_name, count, time_used);
}

/**
 * 小数据性能测试
 */
void test_performance_small(int connfd) {
    printf("\n--- Testing Small Data Performance ---\n");

    // 1w 次
    run_performance_test(connfd, "Small Data 1w", "SET", 10000);

    // 10w 次
    run_performance_test(connfd, "Small Data 10w", "SET", 100000);

    // 100w 次
    run_performance_test(connfd, "Small Data 100w", "SET", 1000000);
}

/**
 * 中数据性能测试
 */
void test_performance_medium(int connfd) {
    printf("\n--- Testing Medium Data Performance ---\n");

    char cmd[512];
    char value[1024];
    memset(value, 'a', 1023);
    value[1023] = '\0';

    struct timeval tv_begin, tv_end;

    gettimeofday(&tv_begin, NULL);

    for (int i = 0; i < 10000; i++) {
        snprintf(cmd, sizeof(cmd), "SET med_key%d %s", i, value);
        testcase(connfd, cmd, "OK\r\n", "PERF-MED-SET");
    }

    gettimeofday(&tv_end, NULL);
    long long time_used = TIME_SUB_MS(tv_end, tv_begin);
    test_record_perf("Medium Data 1w", 10000, time_used);
}

/**
 * 大数据性能测试
 */
void test_performance_large(int connfd) {
    printf("\n--- Testing Large Data Performance ---\n");

    char cmd[256];
    char* large_value = (char*)malloc(16 * 1024 * 1024); // 16MB
    if (large_value) {
        memset(large_value, 'b', 16 * 1024 * 1024 - 1);
        large_value[16 * 1024 * 1024 - 1] = '\0';

        struct timeval tv_begin, tv_end;

        gettimeofday(&tv_begin, NULL);

        for (int i = 0; i < 100; i++) {
            snprintf(cmd, sizeof(cmd), "SET large_key%d ", i);
            // 注意：这里简化处理，实际需要拼接大 value
            testcase(connfd, cmd, "OK\r\n", "PERF-LARGE-SET");
        }

        gettimeofday(&tv_end, NULL);
        long long time_used = TIME_SUB_MS(tv_end, tv_begin);
        test_record_perf("Large Data 100", 100, time_used);

        free(large_value);
    }
}

/* ==================== 并发测试 ==================== */

/**
 * 并发测试子进程函数
 */
void concurrent_test_child(const char* ip, unsigned short port, int child_id) {
    int connfd = connect_server(ip, port);
    if (connfd < 0) {
        exit(1);
    }

    char cmd[128];
    for (int i = 0; i < 1000; i++) {
        snprintf(cmd, sizeof(cmd), "SET conc_%d_%d value_%d", child_id, i, i);
        char* resp_msg = encode_to_resp(cmd);
        send_msg(connfd, resp_msg, strlen(resp_msg));
        free(resp_msg);

        char result[MAX_MSG] = {0};
        recv_msg(connfd, result, MAX_MSG);
    }

    close(connfd);
    exit(0);
}

/**
 * 多进程并发测试
 */
void test_concurrent(const char* ip, unsigned short port) {
    printf("\n--- Testing Concurrent Operations ---\n");

    int num_children = 4;
    pid_t pids[4];

    for (int i = 0; i < num_children; i++) {
        pids[i] = fork();
        if (pids[i] == 0) {
            // 子进程
            concurrent_test_child(ip, port, i);
        } else if (pids[i] < 0) {
            perror("fork");
            return;
        }
    }

    // 等待所有子进程
    for (int i = 0; i < num_children; i++) {
        waitpid(pids[i], NULL, 0);
    }

    printf("Concurrent test completed\n");
}

/* ==================== 持久化测试 ==================== */

/**
 * KSF 快照保存测试
 */
void test_persistence_ksf_save(int connfd) {
    printf("\n--- Testing KSF Snapshot Save ---\n");

    // 设置一些测试数据
    for (int i = 0; i < 100; i++) {
        char cmd[128];
        snprintf(cmd, sizeof(cmd), "SET ksf_save_key%d ksf_save_value%d", i, i);
        testcase(connfd, cmd, "OK\r\n", "KSF-SAVE-SET");
    }

    // 触发保存（这里需要服务器支持 SAVE 命令）
    testcase(connfd, "SAVE", "OK\r\n", "KSF-SAVE-CMD");

    printf("KSF snapshot save test completed\n");
}

/**
 * KSF 快照加载测试
 */
void test_persistence_ksf_load(int connfd) {
    printf("\n--- Testing KSF Snapshot Load ---\n");

    // 验证之前保存的数据
    for (int i = 0; i < 100; i++) {
        char cmd[128];
        char expected[128];
        snprintf(cmd, sizeof(cmd), "GET ksf_save_key%d", i);
        snprintf(expected, sizeof(expected), "ksf_save_value%d\r\n", i);
        testcase(connfd, cmd, expected, "KSF-LOAD-GET");
    }

    printf("KSF snapshot load test completed\n");
}

/**
 * AOF 增量持久化测试
 */
void test_persistence_aof(int connfd) {
    printf("\n--- Testing AOF Persistence ---\n");

    // 启用 AOF（如果支持）
    testcase(connfd, "CONFIG SET appendonly yes", "OK\r\n", "AOF-ENABLE");

    // 执行一系列操作
    for (int i = 0; i < 50; i++) {
        char cmd[128];
        snprintf(cmd, sizeof(cmd), "SET aof_key%d aof_value%d", i, i);
        testcase(connfd, cmd, "OK\r\n", "AOF-SET");
    }

    printf("AOF persistence test completed\n");
}

