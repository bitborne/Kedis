/* ==================== 主函数 ==================== */

void print_usage(const char* prog_name) {
    printf("Usage: %s <ip> <port> <test_mode>\n", prog_name);
    printf("\nTest Modes:\n");
    printf("  all           - Run all tests\n");
    printf("  resp          - RESP protocol tests\n");
    printf("  basic         - Basic operation tests\n");
    printf("  perf          - Performance tests\n");
    printf("  concurrent    - Concurrent tests\n");
    printf("  persistence   - Persistence tests\n");
    printf("  engines       - Engine-specific tests\n");
    printf("  array         - Array engine tests\n");
    printf("  hash          - Hash engine tests\n");
    printf("  rbtree        - Rbtree engine tests\n");
    printf("  skiplist      - Skiplist engine tests\n");
}

int main(int argc, char* argv[]) {
    if (argc != 4) {
        print_usage(argv[0]);
        return -1;
    }

    char* ip = argv[1];
    unsigned short port = atoi(argv[2]);
    char* mode = argv[3];

    // 初始化测试框架
    test_stats_init();
    test_markdown_init();

    // 连接服务器
    int connfd = connect_server(ip, port);
    if (connfd < 0) {
        fprintf(stderr, "Failed to connect to server\n");
        return -1;
    }

    printf("Connected to %s:%d\n", ip, port);
    printf("Running test mode: %s\n", mode);

    struct timeval tv_start, tv_end;
    gettimeofday(&tv_start, NULL);

    // 根据模式执行测试
    if (strcmp(mode, "all") == 0) {
        test_resp_special_chars(connfd);
        test_resp_boundary(connfd);
        test_basic_operations(connfd);
        test_performance_small(connfd);
        test_performance_medium(connfd);
        test_concurrent(ip, port);
        test_persistence_ksf_save(connfd);
        test_persistence_ksf_load(connfd);
        test_engine_array(connfd);
        test_engine_hash(connfd);
        test_engine_rbtree(connfd);
        test_engine_skiplist(connfd);
    }
    else if (strcmp(mode, "resp") == 0) {
        test_resp_special_chars(connfd);
        test_resp_boundary(connfd);
    }
    else if (strcmp(mode, "basic") == 0) {
        test_basic_operations(connfd);
    }
    else if (strcmp(mode, "perf") == 0) {
        test_performance_small(connfd);
        test_performance_medium(connfd);
    }
    else if (strcmp(mode, "concurrent") == 0) {
        test_concurrent(ip, port);
    }
    else if (strcmp(mode, "persistence") == 0) {
        test_persistence_ksf_save(connfd);
        test_persistence_ksf_load(connfd);
        test_persistence_aof(connfd);
    }
    else if (strcmp(mode, "engines") == 0) {
        test_engine_array(connfd);
        test_engine_hash(connfd);
        test_engine_rbtree(connfd);
        test_engine_skiplist(connfd);
    }
    else if (strcmp(mode, "array") == 0) {
        test_engine_array(connfd);
    }
    else if (strcmp(mode, "hash") == 0) {
        test_engine_hash(connfd);
    }
    else if (strcmp(mode, "rbtree") == 0) {
        test_engine_rbtree(connfd);
    }
    else if (strcmp(mode, "skiplist") == 0) {
        test_engine_skiplist(connfd);
    }
    else {
        fprintf(stderr, "Unknown test mode: %s\n", mode);
        print_usage(argv[0]);
        close(connfd);
        test_markdown_close();
        return -1;
    }

    gettimeofday(&tv_end, NULL);
    g_stats.total_time_ms = TIME_SUB_MS(tv_end, tv_start);

    // 清理
    close(connfd);
    test_stats_print();
    test_markdown_close();

    return 0;
}